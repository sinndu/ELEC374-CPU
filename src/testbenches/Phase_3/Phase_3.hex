58A00005 // ori   R1, R4, 5   ; R1 = 0x80000007
2A090000 // shra  R4, R1, R2  ; R4 = 0xF8000000
22A90000 // shr   R5, R5, R2  ; R5 = 0x8
928000A3 // st    0xA3, R5    ; (0xA3) = 0x8 new value in memory with address 0xA3
42810000 // rol   R5, R0, R2  ; R5 = 0x680
1B900000 // or    R7, R2, R0  ; R7 = 0x6C
12280000 // and   R4, R5, R0  ; R4 = 0
93A00089 // st    0x89(R4), R7; (0x89) = 0x6C new value in memory with address 0x89
082B8000 // sub   R0, R5, R7  ; R0 = 0x614
32290000 // shl   R4, R5, R2  ; R4 = 0x6800
8B800007 // ldi   R7, 7       ; R7 = 7
89800019 // ldi   R3, 0x19    ; R3 = 0x19
69B80000 // mul   R3, R7      ; HI = 0; LO = 0xAF
C0800000 // mfhi  R1          ; R1 = 0
CB000000 // mflo  R6          ; R6 = 0xAF
61B80000 // div   R3, R7      ; HI = 4 , LO = 3
8C380002 // ldi   R8, 2(R7)   ; R8 = 9 setting up argument registers
8C9FFFFC // ldi   R9, -4(R3)  ; R9 = 0x15 R8, R9, R10, and R11
