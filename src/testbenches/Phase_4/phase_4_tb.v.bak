`timescale 1ns/10ps
module phase_4_tb;
    reg stop;
    reg [31:0] in_inport_data;
    wire [7:0] seven_seg_ones;
    wire [7:0] seven_seg_tens;
    wire tb_stop;
	wire run;

    // Instance of the Computer
    Computer SRC(
        .clock(clock), .reset(~reset),
        .stop(~stop),

        .in_port_data(in_inport_data),
        .seven_seg_ones(seven_seg_ones),
        .seven_seg_tens(seven_seg_tens),
        .tb_stop(tb_stop),
		.run(run)
    );

	always@(negedge reset) begin
		//we need to reload the machine code into memory since clear signal resets it
		$readmemh("Phase_4.hex", SRC.memory.mem);
	end
    always@(*) begin
        if (tb_stop) begin
            $stop;
        end
    end
endmodule